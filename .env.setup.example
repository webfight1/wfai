# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file content to your .env file
# 2. Replace the placeholder values with your actual credentials
# 3. Run: php artisan serve
# 4. Open: http://localhost:8000/chat
# ============================================

# CRM API Configuration
# Your external CRM API base URL (without trailing slash)
CRM_API_URL=https://your-crm-api.com

# Your CRM API Bearer token
CRM_API_TOKEN=your_bearer_token_here

# OpenAI Configuration
# Your OpenAI API key (get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ============================================
# EXAMPLE CONFIGURATION
# ============================================
# CRM_API_URL=https://api.mycrm.com
# CRM_API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# OPENAI_API_KEY=sk-proj-abc123xyz...
# OPENAI_MODEL=gpt-4o-mini
# ============================================
